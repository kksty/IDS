# IDS 服务示例 .env 文件（含注释）
# 使用方法：复制为 .env 并根据部署环境修改相应值。
# 格式：KEY=VALUE；注释以 # 开头。

# ---------------- 重要：数据库配置（必需） ----------------
# 例如：Postgres
IDS_DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/ids_db
# 或者 SQLite（开发）：IDS_DATABASE_URL=sqlite:///./ids.db

# ---------------- 服务器与网络 ----------------
# 后端绑定地址与端口
IDS_HOST=0.0.0.0
IDS_PORT=8000
# 开发时可启用热重载
IDS_RELOAD=false
# 抓包默认网卡（示例：eth0、ens3、lo）
IDS_NETWORK_INTERFACE=eth0
# BPF 过滤表达式（仅嗅探匹配的流量）
IDS_BPF_FILTER=ip

# ---------------- 日志 ----------------
# 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL
IDS_LOG_LEVEL=INFO
# 是否将日志写入文件（true/false）
IDS_LOG_TO_FILE=false
# 日志格式字符串
IDS_LOG_FORMAT=%(asctime)s %(levelname)s [%(name)s] %(message)s

# ---------------- 嗅探/缓冲 ----------------
# 会话上下文超时（秒），未活动会话将被回收
IDS_CONTEXT_TIMEOUT=300.0
# 每个上下文的最大缓冲字节数（bytes）
IDS_MAX_BUFFER_SIZE=262144

# ---------------- 嗅探性能 ----------------
# 嗅探入队缓冲大小与后台 worker 数量
IDS_SNIFFER_QUEUE_SIZE=5000
IDS_SNIFFER_WORKERS=2

# ---------------- 行为分析（Behavior） ----------------
# 连接检测窗口（秒）
IDS_CONNECTION_WINDOW_SIZE=60
# 单窗口允许的最大连接数（阈值）
IDS_MAX_CONNECTIONS_PER_WINDOW=200
# 端口扫描检测窗口与阈值
IDS_PORT_SCAN_WINDOW=300
IDS_PORT_SCAN_THRESHOLD=40
IDS_PORT_SCAN_MIN_TARGETS=5
IDS_PORT_SCAN_MIN_PORTS=40
# 认证失败检测阈值与窗口
IDS_MAX_AUTH_FAILURES=5
IDS_AUTH_WINDOW_SIZE=300
# 行为告警防抖/冷却（秒），避免重复告警
IDS_BEHAVIOR_ALERT_COOLDOWN=120
IDS_PORT_SCAN_ALERT_COOLDOWN=180
IDS_HIGH_CONN_ALERT_COOLDOWN=120

# ---------------- 关联分析（Correlation） ----------------
# 观察窗口（秒）：用于聚合同一 src_ip 的告警以判定“可疑攻击者”
# 默认：600（10 分钟）
IDS_CORR_WINDOW_SIZE=600
# 触发关联所需的不同规则数（多样性阈值）
IDS_CORR_MIN_RULE_DIVERSITY=4
# 触发关联所需的累计告警数（含行为告警权重）
IDS_CORR_MIN_ALERTS=8
# 行为告警在关联计数中的权重（整数）
IDS_CORR_BEHAVIOR_WEIGHT=1
# 关联告警冷却（秒），同一 src_ip 在冷却期内不会重复生成关联告警
IDS_CORR_ALERT_COOLDOWN=300

# ---------------- 规则 / 引擎 ----------------
# 规则引擎重建与数据库连接池（可根据负载调整）
IDS_DB_POOL_SIZE=10
IDS_DB_MAX_OVERFLOW=20
IDS_DB_POOL_TIMEOUT=30
IDS_DB_POOL_RECYCLE=3600

# ---------------- JWT / 身份认证 ----------------
# 生产环境务必替换为强随机密钥
JWT_SECRET=please_change_this_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---------------- 统计 / 采样 ----------------
IDS_SAMPLE_INTERVAL=1.0
IDS_EWMA_ALPHA=0.2
IDS_SPIKE_FACTOR_PACKETS=5.0
IDS_SPIKE_FACTOR_BYTES=5.0
IDS_SUSTAIN_WINDOWS=3
IDS_WARMUP_WINDOWS=30
IDS_SESSION_TIMEOUT=3600
IDS_DEDUPE_WINDOW=10

# ---------- 说明：常见调整示例 ----------
# 将关联窗口改为 5 分钟：IDS_CORR_WINDOW_SIZE=300
# 缩短检查冷却以更频繁告警（谨慎）：IDS_CORR_ALERT_COOLDOWN=120

# End of file