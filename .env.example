# IDS 系统环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# 数据库配置（必需）
IDS_DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/ids_db

# 网络配置
IDS_NETWORK_INTERFACE=eth0
# IDS_NETWORK_INTERFACE=lo  # 本地回环（开发环境）

# 服务器配置
IDS_HOST=0.0.0.0
IDS_PORT=8000
IDS_RELOAD=false

# 日志配置
IDS_LOG_LEVEL=INFO
# IDS_LOG_LEVEL=DEBUG  # 开发环境
IDS_LOG_FORMAT=%(asctime)s %(levelname)s [%(name)s] %(message)s
IDS_LOG_TO_FILE=false

# 性能配置
IDS_CONTEXT_TIMEOUT=300.0
IDS_MAX_BUFFER_SIZE=262144

# 数据库连接池配置
IDS_DB_POOL_SIZE=10
IDS_DB_MAX_OVERFLOW=20
IDS_DB_POOL_TIMEOUT=30
IDS_DB_POOL_RECYCLE=3600

# 行为分析配置
IDS_CONNECTION_WINDOW_SIZE=60
IDS_MAX_CONNECTIONS_PER_WINDOW=100
IDS_PORT_SCAN_WINDOW=300
IDS_PORT_SCAN_THRESHOLD=20
IDS_MAX_AUTH_FAILURES=5
IDS_AUTH_WINDOW_SIZE=300
IDS_SAMPLE_INTERVAL=1.0
IDS_EWMA_ALPHA=0.2
IDS_SPIKE_FACTOR_PACKETS=5.0
IDS_SPIKE_FACTOR_BYTES=5.0
IDS_SUSTAIN_WINDOWS=3
IDS_WARMUP_WINDOWS=30
IDS_SESSION_TIMEOUT=3600
IDS_DEDUPE_WINDOW=10