# Test Snort rules with various port formats to validate fixes
alert tcp any any -> any 80 (msg:"HTTP GET request"; content:"GET"; http_method; sid:1000001; rev:1;)
alert tcp any any -> any 22 (msg:"SSH login attempt"; content:"password"; sid:1000002; rev:1;)
alert tcp any any -> any 21 (msg:"FTP password attempt"; content:"PASS"; sid:1000003; rev:1;)
alert tcp any any -> any 3306 (msg:"SQL injection attempt"; content:"UNION SELECT"; nocase; sid:1000004; rev:1;)
alert tcp any any -> any any (msg:"Multiple keywords detected"; content:"password"; content:"admin"; distance:10; sid:1000005; rev:1;)
alert tcp any any -> any any (msg:"Regex pattern match"; pcre:"/password|passwd|pwd/i"; sid:1000006; rev:1;)
alert tcp any any -> any 80 (msg:"File upload detected"; content:"Content-Disposition"; content:"filename"; distance:20; sid:1000007; rev:1;)
alert icmp any any -> any any (msg:"ICMP ping sweep"; itype:8; sid:1000008; rev:1;)
alert udp any any -> any 53 (msg:"DNS query"; content:"|01 00 00 01|"; offset:2; depth:2; sid:1000009; rev:1;)
alert tcp any any -> any any (msg:"Large TCP packet"; dsize:>1000; sid:1000010; rev:1;)

# Rules with problematic port formats that were fixed
alert tcp any any -> any 1024: (msg:"High port range test"; content:"test"; sid:1000011; rev:1;)
alert tcp any any -> any !21:23 (msg:"Negated port range"; content:"test"; sid:1000012; rev:1;)
alert tcp any any -> any !21 (msg:"Negated single port"; content:"test"; sid:1000013; rev:1;)
alert tcp any any -> any 1:1023 (msg:"Low port range"; content:"test"; sid:1000014; rev:1;)
alert tcp any any -> any 443 (msg:"HTTPS port"; content:"test"; sid:1000015; rev:1;)

# More rules to reach a reasonable test size
alert tcp any any -> any 25 (msg:"SMTP traffic"; content:"MAIL FROM"; sid:1000016; rev:1;)
alert tcp any any -> any 110 (msg:"POP3 traffic"; content:"USER"; sid:1000017; rev:1;)
alert tcp any any -> any 143 (msg:"IMAP traffic"; content:"LOGIN"; sid:1000018; rev:1;)
alert tcp any any -> any 993 (msg:"IMAPS traffic"; content:"test"; sid:1000019; rev:1;)
alert tcp any any -> any 995 (msg:"POP3S traffic"; content:"test"; sid:1000020; rev:1;)

alert tcp any any -> any 3389 (msg:"RDP traffic"; content:"test"; sid:1000021; rev:1;)
alert tcp any any -> any 5900 (msg:"VNC traffic"; content:"test"; sid:1000022; rev:1;)
alert tcp any any -> any 8080 (msg:"HTTP alt port"; content:"test"; sid:1000023; rev:1;)
alert tcp any any -> any 8443 (msg:"HTTPS alt port"; content:"test"; sid:1000024; rev:1;)
alert tcp any any -> any 9000 (msg:"Common dev port"; content:"test"; sid:1000025; rev:1;)

