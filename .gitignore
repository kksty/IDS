# ============================================
# IDS 项目 .gitignore 文件
# ============================================

# ------------------- Python -------------------
# 字节码和缓存文件
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
.venv/
venv/
myvenv/
ENV/
env/

# 测试和覆盖率
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# 打包和分发
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# ------------------- Node.js -------------------
# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建输出
frontend/dist/
dist/
.next/
.nuxt/
.vite/

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# ------------------- 环境和配置 -------------------
# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# 敏感信息
.secrets/
secrets/
config/secrets.json
*.key
*.pem
*.crt

# ------------------- IDE 和编辑器 -------------------
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# PyCharm / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ------------------- 操作系统 -------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------- 数据库和数据 -------------------
# 数据库文件
*.db
*.sqlite
*.sqlite3
*.sql

# 数据文件
*.csv
*.json
data/
logs/

# ------------------- 容器和部署 -------------------
# Docker
.dockerignore

# Kubernetes
*.yaml.bak
*.yml.bak

# ------------------- 临时文件 -------------------
# 临时文件
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.swp
*.swo

# ------------------- 项目特定 -------------------
# IDS 项目特定
ids.log
*.pcap
*.pcapng
captures/
alerts/
reports/

# 网络嗅探数据
wireshark/
tcpdump/
snort_logs/

# 性能分析和调试
*.prof
profile/
benchmark_results/
debug/
*.dump

# 测试文件（如果不需要版本控制）
# test.html
# tests/test_*.py

# 前端构建缓存
.parcel-cache/
.vite/

# Python 类型检查
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter Notebook
.ipynb_checkpoints/

# ------------------- 安全和隐私 -------------------
# 私钥和证书
*.key
*.pem
*.crt
*.cer
*.p12
*.pfx

# 密码和令牌
passwords.txt
tokens.txt
credentials.json

# ------------------- CI/CD -------------------
# GitHub Actions
.github/workflows/*.log

# GitLab CI
.gitlab-ci.yml.bak

# Jenkins
Jenkinsfile.bak

# ------------------- 文档 -------------------
# 临时文档
*.tmp.md
*.bak.md

# LaTeX
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc

# ------------------- 其他 -------------------
# 自定义忽略
# 添加项目特定的忽略规则

README.md